# ==========================================
# codetwine Environment Variable Configuration
# Copy this file to .env and set each value
# Commented-out items use their default values
# Uncomment and modify values as needed
# ==========================================

# LLM API key (can be omitted for providers that don't require authentication, e.g. Ollama)
LLM_API_KEY=your-api-key-here

# API base URL (set when the endpoint differs from the default, e.g. Ollama, Azure OpenAI, self-hosted)
# If not set, litellm uses the default URL for each provider
#   Ollama:         http://localhost:11434
#   Azure OpenAI:   https://your-resource.openai.azure.com
# LLM_API_BASE=http://localhost:11434

# LLM model name used for summary and design document generation (required when ENABLE_LLM_DOC=True)
# Supports multiple providers via litellm. Specify the provider with a model name prefix.
#   Anthropic:  anthropic/<model>
#   OpenAI:     openai/<model>
#   Google:     gemini/<model>
#   Ollama:     ollama/<model>
#   Azure:      azure/<model>
LLM_MODEL=anthropic/claude-sonnet-4-6

# Root directory of the project to analyze (absolute path)
# Can also be specified via CLI argument --project-dir (overrides this value)
DEFAULT_PROJECT_DIR=/path/to/your/project_name

# Output directory for analysis results (default: output/ under repository root)
# Can also be specified via CLI argument --output-dir (overrides this value)
# When only --project-dir is specified, this value is ignored and the default is used
# DEFAULT_OUTPUT_DIR=/path/to/output

# Retry settings
MAX_RETRIES=3
RETRY_WAIT=2

# Number of parallel workers (default: 4)
MAX_WORKERS=4

# File/directory exclusion patterns (comma-separated)
# Directory and file name patterns to exclude during os.walk file traversal
# Supports fnmatch-style glob patterns (e.g. *.pyc, test_*, .venv)
# Patterns are matched against directory/file names (basename)
# Default when not set: __pycache__,.git,.github,.venv,node_modules
# EXCLUDE_PATTERNS=__pycache__,.git,.github,.venv,node_modules

# Path to design document template (default: doc_template.json under repository root)
# Path to a JSON file defining the document chapter structure and prompts
# DOC_TEMPLATE_PATH=/path/to/doc_template.json

# Token limit for LLM output (default: 8192)
# Maximum number of tokens in the LLM response when generating design documents
# DOC_MAX_TOKENS=8192

# Enable/disable LLM generation of design documents (True/False)
# When False, the entire design document step is skipped
ENABLE_LLM_DOC=True

# Maximum character count for summaries (default: 600)
# SUMMARY_MAX_CHARS=600

# LLM output language (default: English)
# Language used for summary and design document generation (e.g. Japanese, English, Chinese)
OUTPUT_LANGUAGE=English


